<% activePage = 'logs' %>
<div class="page-header">
  <h2>VPN Session Logs</h2>
  <div class="header-actions">
    <a href="/logs" class="btn">🔄 Refresh</a>
  </div>
</div>

<% if (active.length > 0) { %>
<div class="card">
  <h3>Active Sessions</h3>
  <table class="table">
    <thead>
      <tr><th>User</th><th>Client IP</th><th>Assigned IP</th><th>Connected</th><th>⬆</th><th>⬇</th></tr>
    </thead>
    <tbody>
      <% active.forEach(l => { %>
        <tr>
          <td><strong><%= l.username %></strong></td>
          <td><%= l.client_ip || '-' %></td>
          <td><code><%= l.assigned_ip || '-' %></code></td>
          <td><%= l.connected_at %></td>
          <td><%= (l.bytes_sent / 1024 / 1024).toFixed(2) %> MB</td>
          <td><%= (l.bytes_recv / 1024 / 1024).toFixed(2) %> MB</td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<% } %>

<div class="card">
  <h3>Session History</h3>
  <table class="table">
    <thead>
      <tr>
        <th>Time</th>
        <th>User</th>
        <th>Client IP</th>
        <th>Assigned IP</th>
        <th>Duration</th>
        <th>⬆ Sent</th>
        <th>⬇ Received</th>
        <th>Reason</th>
      </tr>
    </thead>
    <tbody>
      <% if (logs.length === 0) { %>
        <tr><td colspan="8" class="text-muted">Belum ada riwayat session</td></tr>
      <% } %>
      <% logs.forEach(l => { %>
        <tr>
          <td class="log-time"><%= l.connected_at %></td>
          <td><strong><%= l.username %></strong></td>
          <td><%= l.client_ip || '-' %></td>
          <td><code><%= l.assigned_ip || '-' %></code></td>
          <td>
            <% if (l.disconnected_at) { %>
              <%= Math.round((new Date(l.disconnected_at) - new Date(l.connected_at)) / 60000) %> min
            <% } else { %>-<% } %>
          </td>
          <td><%= (l.bytes_sent / 1024 / 1024).toFixed(2) %> MB</td>
          <td><%= (l.bytes_recv / 1024 / 1024).toFixed(2) %> MB</td>
          <td><%= l.disconnect_reason || 'completed' %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <div class="pagination">
    <% if (page > 1) { %><a href="/logs?page=<%= page - 1 %>" class="btn-sm">← Prev</a><% } %>
    <span>Page <%= page %> of <%= totalPages %> (<%= totalLogs %> total)</span>
    <% if (page < totalPages) { %><a href="/logs?page=<%= page + 1 %>" class="btn-sm">Next →</a><% } %>
  </div>
</div>
