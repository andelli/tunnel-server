<% activePage = 'logs' %>
<div class="page-header">
  <h2>Event Logs</h2>
  <div class="header-actions">
    <a href="/logs" class="btn">🔄 Refresh</a>
  </div>
</div>

<div class="card">
  <div class="log-filters">
    <a href="/logs" class="btn-sm <%= !category ? 'active' : '' %>">All</a>
    <a href="/logs?category=info" class="btn-sm <%= category === 'info' ? 'active' : '' %>">Info</a>
    <a href="/logs?category=warn" class="btn-sm <%= category === 'warn' ? 'active' : '' %>">Warning</a>
    <a href="/logs?category=error" class="btn-sm <%= category === 'error' ? 'active' : '' %>">Error</a>
  </div>

  <table class="table table-logs">
    <thead>
      <tr>
        <th>Time</th>
        <th>Level</th>
        <th>Message</th>
      </tr>
    </thead>
    <tbody>
      <% if (logs.length === 0) { %>
        <tr><td colspan="3" class="text-muted">No logs found</td></tr>
      <% } %>
      <% logs.forEach(l => { %>
        <tr class="log-<%= l.level %>">
          <td class="log-time"><%= l.timestamp %></td>
          <td><span class="badge badge-<%= l.level %>"><%= l.level %></span></td>
          <td><%= l.message %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <div class="pagination">
    <% if (page > 1) { %><a href="/logs?page=<%= page - 1 %><%= category ? '&category=' + category : '' %>" class="btn-sm">← Prev</a><% } %>
    <span>Page <%= page %> of <%= totalPages %> (<%= totalLogs %> total)</span>
    <% if (page < totalPages) { %><a href="/logs?page=<%= page + 1 %><%= category ? '&category=' + category : '' %>" class="btn-sm">Next →</a><% } %>
  </div>
</div>
