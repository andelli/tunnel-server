<% activePage = 'sessions' %>
<div class="page-header">
  <h2>Active Sessions</h2>
  <button class="btn" onclick="location.reload()">🔄 Refresh</button>
</div>

<div class="card">
  <table class="table" id="sessions-table">
    <thead>
      <tr>
        <th>Username</th>
        <th>Client IP</th>
        <th>Assigned IP</th>
        <th>Connected</th>
        <th>Last Seen</th>
        <th>⬆ Sent</th>
        <th>⬇ Received</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
      <% if (sessions.length === 0) { %>
        <tr><td colspan="8" class="text-center text-muted">No active sessions</td></tr>
      <% } %>
      <% sessions.forEach(s => { %>
        <tr>
          <td><strong><%= s.username %></strong></td>
          <td><%= s.client_ip || '-' %></td>
          <td><code><%= s.assigned_ip || '-' %></code></td>
          <td><%= s.connected_at %></td>
          <td><%= s.last_seen %></td>
          <td><%= (s.bytes_sent / 1024 / 1024).toFixed(2) %> MB</td>
          <td><%= (s.bytes_recv / 1024 / 1024).toFixed(2) %> MB</td>
          <td>
            <form method="POST" action="/sessions/<%= s.id %>/kill" onsubmit="return confirm('Kill this session?')">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn-sm btn-danger">Disconnect</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<script>setTimeout(() => location.reload(), 15000);</script>
