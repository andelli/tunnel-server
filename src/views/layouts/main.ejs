<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tunnel Server - <%= typeof title !== 'undefined' ? title : 'Dashboard' %></title>
  <link rel="stylesheet" href="/css/app.css">
</head>
<body>
  <nav class="sidebar">
    <div class="sidebar-header">
      <h1>Tunnel VPN</h1>
      <span class="badge">Gateway</span>
    </div>
    <ul class="nav-links">
      <li><a href="/" class="<%= activePage === 'dashboard' ? 'active' : '' %>">📊 Dashboard</a></li>
      <li><a href="/users" class="<%= activePage === 'users' ? 'active' : '' %>">👥 Users</a></li>
      <li><a href="/sessions" class="<%= activePage === 'sessions' ? 'active' : '' %>">🔌 Sessions</a></li>
      <li><a href="/configs" class="<%= activePage === 'configs' ? 'active' : '' %>">⚙️ Settings</a></li>
      <li><a href="/logs" class="<%= activePage === 'logs' ? 'active' : '' %>">📋 Logs</a></li>
    </ul>
    <div class="sidebar-footer">
      <span class="user-info"><%= session?.username || '' %></span>
      <div style="display:flex;gap:8px;font-size:0.8rem">
        <a href="/change-password" style="color:var(--text-muted);text-decoration:none">Ganti PW</a>
        <a href="/logout" class="btn-logout">Logout</a>
      </div>
    </div>
  </nav>

  <main class="main-content">
    <%- body %>
  </main>

  <script src="/js/app.js"></script>
</body>
</html>
