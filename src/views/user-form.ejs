<% activePage = 'users' %>
<div class="page-header">
  <h2><%= user ? 'Edit User' : 'Add User' %></h2>
  <a href="/users" class="btn">← Back</a>
</div>

<div class="card">
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form method="POST" action="<%= user ? '/users/' + user.id : '/users' %>" class="form">
    <div class="form-group">
      <label for="username">Username</label>
      <input type="text" id="username" name="username" value="<%= user ? user.username : '' %>" <%= user ? 'readonly' : 'required' %>>
    </div>

    <div class="form-group">
      <label for="notes">Notes</label>
      <textarea id="notes" name="notes" rows="2"><%= user ? user.notes || '' : '' %></textarea>
    </div>

    <div class="form-group">
      <label class="checkbox-label">
        <input type="checkbox" name="enabled" value="1" <%= !user || user.enabled ? 'checked' : '' %>> Account Active
      </label>
    </div>

    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <button type="submit" class="btn btn-primary"><%= user ? 'Update' : 'Create' %> User</button>
  </form>
</div>

<% if (user) { %>
<div class="card">
  <h3>WireGuard Keys</h3>
  <table class="table">
    <tr><td>Tunnel IP</td><td><code><%= user.wg_address || '-' %></code></td></tr>
    <tr><td>Public Key</td><td><code style="font-size:0.8em;word-break:break-all"><%= user.wg_public_key || '-' %></code></td></tr>
    <tr><td>Private Key</td><td><code style="font-size:0.8em;word-break:break-all"><%= user.wg_private_key ? '•••••••• (hidden)' : '-' %></code></td></tr>
    <tr><td>Preshared Key</td><td><code style="font-size:0.8em;word-break:break-all"><%= user.wg_preshared_key ? '•••••••• (hidden)' : '-' %></code></td></tr>
    <tr><td>Created</td><td><%= user.created_at %></td></tr>
    <tr><td>Updated</td><td><%= user.updated_at %></td></tr>
  </table>
  <div style="margin-top:10px;display:flex;gap:8px">
    <a href="/users/<%= user.id %>/config" class="btn-sm" download>📥 Download Config</a>
    <a href="/users/<%= user.id %>/qr" class="btn-sm" target="_blank">📱 QR Code</a>
  </div>
</div>
<% } %>
