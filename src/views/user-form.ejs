<% activePage = 'users' %>
<div class="page-header">
  <h2><%= user ? 'Edit User' : 'Add User' %></h2>
  <a href="/users" class="btn">← Back</a>
</div>

<div class="card">
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form method="POST" action="<%= user ? '/users/' + user.id : '/users' %>" class="form">
    <div class="form-group">
      <label for="username">Username</label>
      <input type="text" id="username" name="username" value="<%= user ? user.username : '' %>" <%= user ? 'readonly' : 'required' %>>
    </div>

    <div class="form-group">
      <label for="password">Password <small>(for L2TP/IPsec)</small></label>
      <input type="text" id="password" name="password" value="" placeholder="<%= user ? 'Leave empty to keep current' : 'Auto-generate if empty' %>">
    </div>

    <div class="form-group">
      <label for="notes">Notes</label>
      <textarea id="notes" name="notes" rows="2"><%= user ? user.notes || '' : '' %></textarea>
    </div>

    <div class="form-group">
      <label>Protocol Access</label>
      <div class="checkbox-group">
        <label class="checkbox-label">
          <input type="checkbox" name="wg_enabled" value="1" <%= !user || user.wg_enabled ? 'checked' : '' %>> WireGuard
        </label>
        <label class="checkbox-label">
          <input type="checkbox" name="ovpn_enabled" value="1" <%= !user || user.ovpn_enabled ? 'checked' : '' %>> OpenVPN
        </label>
        <label class="checkbox-label">
          <input type="checkbox" name="l2tp_enabled" value="1" <%= !user || user.l2tp_enabled ? 'checked' : '' %>> L2TP/IPsec
        </label>
      </div>
    </div>

    <div class="form-group">
      <label class="checkbox-label">
        <input type="checkbox" name="enabled" value="1" <%= !user || user.enabled ? 'checked' : '' %>> Account Active
      </label>
    </div>

    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <button type="submit" class="btn btn-primary"><%= user ? 'Update' : 'Create' %> User</button>
  </form>
</div>

<% if (user) { %>
<div class="card">
  <h3>User Info</h3>
  <table class="table">
    <tr><td>WireGuard IP</td><td><code><%= user.wg_address || '-' %></code></td></tr>
    <tr><td>Public Key</td><td><code style="font-size:0.8em"><%= user.wg_public_key || '-' %></code></td></tr>
    <tr><td>Created</td><td><%= user.created_at %></td></tr>
    <tr><td>Updated</td><td><%= user.updated_at %></td></tr>
  </table>
</div>
<% } %>
