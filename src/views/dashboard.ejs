<% activePage = 'dashboard' %>
<div class="page-header">
  <h2>Dashboard</h2>
  <div class="header-actions">
    <a href="/users/new" class="btn btn-primary">+ Add User</a>
  </div>
</div>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-value" id="stat-total-users"><%= stats.totalUsers %></div>
    <div class="stat-label">Total Users</div>
  </div>
  <div class="stat-card stat-active">
    <div class="stat-value" id="stat-active-users"><%= stats.activeUsers %></div>
    <div class="stat-label">Online Now</div>
  </div>
  <div class="stat-card">
    <div class="stat-value" id="stat-enabled-users"><%= stats.enabledUsers %></div>
    <div class="stat-label">Enabled</div>
  </div>
  <div class="stat-card">
    <div class="stat-value" id="stat-bandwidth"><%= (stats.total_recv_all / 1024 / 1024 / 1024).toFixed(2) %> GB</div>
    <div class="stat-label">Total Traffic</div>
  </div>
</div>

<div class="dashboard-grid">
  <div class="card">
    <h3>Active Sessions</h3>
    <div class="protocol-list">
      <% if (protocols.length === 0) { %>
        <p class="text-muted">No active sessions</p>
      <% } %>
      <% protocols.forEach(p => { %>
        <div class="protocol-item">
          <span class="protocol-name">WireGuard</span>
          <span class="protocol-count"><%= p.count %> online</span>
        </div>
      <% }) %>
    </div>
  </div>

  <div class="card">
    <h3>Quick Actions</h3>
    <div class="quick-actions">
      <a href="/users/new" class="action-btn">➕ New User</a>
      <a href="/sessions" class="action-btn">🔌 Active Sessions</a>
      <a href="/configs" class="action-btn">⚙️ Settings</a>
    </div>
  </div>
</div>

<div class="card">
  <h3>Recent Events</h3>
  <div class="events-list">
    <% if (recentEvents.length === 0) { %>
      <p class="text-muted">No events yet</p>
    <% } %>
    <% recentEvents.forEach(e => { %>
      <div class="event-item">
        <span class="event-time"><%= e.timestamp %></span>
        <span class="event-level event-<%= e.level %>"><%= e.level %></span>
        <span class="event-category"><%= e.category %></span>
        <span class="event-msg"><%= e.message %></span>
      </div>
    <% }) %>
  </div>
</div>
